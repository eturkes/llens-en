# LLENS environment variables (this file is git-tracked; the actual .env is gitignored)
#
# Usage:
#   cp .env.example .env
#   # Edit .env and fill in real values
#   docker compose up -d

# Grafana admin password
# Only seeded on first startup (when grafana_data volume is empty).
# If an existing volume remains, the user table settings inside it take precedence.
GRAFANA_ADMIN_PASSWORD=replace-me

# Open WebUI admin API Key
# Obtain: OWUI Settings → Account → API Keys → Create new
# Used by scripts/owui/sync-functions.py to sync filters/*.py to OWUI
OWUI_API_KEY=
# OWUI endpoint (default is localhost:8080 exposed by compose)
# OWUI_BASE_URL=http://localhost:8080
