{
  "uid": "sglang-h200",
  "title": "SGLang H200 Dashboard",
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "title": "--- LLM Performance ---",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "TTFT (Time to First Token)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(sglang:time_to_first_token_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(sglang:time_to_first_token_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(sglang:time_to_first_token_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "title": "Generation Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "tok/s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sglang:gen_throughput",
          "legendFormat": "tokens/s"
        }
      ]
    },
    {
      "title": "Concurrent Requests / Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sglang:num_running_reqs",
          "legendFormat": "Running"
        },
        {
          "expr": "sglang:num_queue_reqs",
          "legendFormat": "Queued"
        }
      ]
    },
    {
      "title": "Token Processing Rate (tokens/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "tok/s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(sglang:prompt_tokens_total[5m])",
          "legendFormat": "Input (prompt)"
        },
        {
          "expr": "rate(sglang:generation_tokens_total[5m])",
          "legendFormat": "Output (generation)"
        }
      ]
    },
    {
      "title": "KV Cache Used Tokens",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sglang:num_used_tokens",
          "legendFormat": "Used tokens"
        }
      ]
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sglang:realtime_tokens_total{mode=\"prefill_cache\"}[5m])) / (sum(rate(sglang:realtime_tokens_total{mode=\"prefill_cache\"}[5m])) + sum(rate(sglang:realtime_tokens_total{mode=\"prefill_compute\"}[5m])))",
          "legendFormat": "Cache hit rate"
        }
      ]
    },
    {
      "title": "Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 9 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(sglang:e2e_request_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(sglang:e2e_request_latency_seconds_bucket[5m]))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "title": "--- GPU Hardware ---",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "title": "GPU Temperature (℃)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 83 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "VRAM Usage (MiB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}} Used"
        }
      ]
    },
    {
      "title": "Power Consumption (W)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "Memory Clock (MHz)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "rotmhz",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_MEM_CLOCK",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "SM Clock (MHz)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "rotmhz",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_SM_CLOCK",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "NVLink Bandwidth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_NVLINK_BANDWIDTH_TOTAL",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
